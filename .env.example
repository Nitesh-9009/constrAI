# Optional — Kayakalp works fully without any keys (deterministic demo intelligence).
# Add an OpenAI-compatible key to make the assistant answer with a live LLM.

# OpenAI-compatible endpoint (OpenAI, Groq, Together, OpenRouter, local Ollama, etc.)
OPENAI_API_KEY=
# Base URL of the OpenAI-compatible API (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Chat model name (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
