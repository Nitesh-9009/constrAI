# ─────────────────────────────────────────────────────────────
# ConstrAI environment variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Supabase — enables real accounts (sign up / log in) and the cloud database.
# Find these in your Supabase project: Settings → API.
# Without them, the app runs in demo mode with built-in sample data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Keep this one SECRET (server-only). Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for auth redirects). E.g. https://constrai.vercel.app
NEXT_PUBLIC_SITE_URL=
